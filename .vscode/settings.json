{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "cSpell.words": [
    "DISPLAYNAME",
    "elif",
    "extname",
    "JSDOCS",
    "METADESCRIPTION",
    "nextstarter",
    "rstrip",
    "SARIF",
    "toggleable",
    "WCAG"
  ]
}